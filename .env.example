# ============================================================
#  n8n — Environment Variables
#  Copy file này: cp .env.example .env  rồi chỉnh lại
# ============================================================

# ── Địa chỉ truy cập ─────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Nếu deploy lên server thật, đổi thành domain của bạn:
# N8N_HOST=n8n.yourdomain.com
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://n8n.yourdomain.com/
# N8N_EDITOR_BASE_URL=https://n8n.yourdomain.com

WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678

# ── Bảo mật ──────────────────────────────────────────────────
# QUAN TRỌNG: đổi giá trị này trước khi chạy lần đầu!
N8N_ENCRYPTION_KEY=super-secret-key-change-me

# ── Timezone ─────────────────────────────────────────────────
TIMEZONE=Asia/Ho_Chi_Minh

# ── Log level: error | warn | info | verbose | debug ─────────
N8N_LOG_LEVEL=info

# ── Database (mặc định SQLite) ────────────────────────────────
DB_TYPE=sqlite

# Nếu dùng Postgres, bỏ comment các dòng dưới và đổi DB_TYPE
# DB_TYPE=postgresdb
# POSTGRES_DB=n8n
# POSTGRES_USER=n8n
# POSTGRES_PASSWORD=strong_password_here
